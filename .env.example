# =============================================================================
# NovaService - Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# Telegram Bot
TELEGRAM_TOKEN=your_telegram_bot_token_here

# DeepSeek API
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Admin ID (user ID Telegram Mas)
ADMIN_ID=123456789

# =============================================================================
# Service Configuration
# =============================================================================

# Therapist Service Duration (minutes)
SERVICE_THERAPIST_BACK_DURATION=30
SERVICE_THERAPIST_FRONT_DURATION=30
SERVICE_THERAPIST_VITAL_DURATION=120

# Pelacur Service Duration (minutes)
SERVICE_PELACUR_DURATION=600

# Prices
SERVICE_BJ_PRICE=500000
SERVICE_SEX_PRICE=1000000
SERVICE_PELACUR_PRICE=10000000

# Minimum Negotiation Prices
SERVICE_BJ_MIN_PRICE=200000
SERVICE_SEX_MIN_PRICE=700000

# =============================================================================
# Webhook (untuk Railway)
# =============================================================================
WEBHOOK_PATH=/webhook
RAILWAY_PUBLIC_DOMAIN=your-app.railway.app

# =============================================================================
# Optional
# =============================================================================
LOG_LEVEL=INFO
VULGAR_MODE_ENABLED=true
AFTERCARE_ENABLED=true
AUTO_BACKUP_ENABLED=true
